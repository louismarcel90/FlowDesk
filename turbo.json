{
  "envMode": "strict",
  "globalEnv": [
    "NODE_ENV",
    "JWT_ACCESS_SECRET",
    "JWT_REFRESH_SECRET",
    "DATABASE_URL",
    "REDIS_URL",
    "OPA_URL"
  ],

  "tasks": {
    "lint": { "dependsOn": ["^lint"] },
    "build": { "dependsOn": ["^build"] },
    "typecheck": { "dependsOn": ["^build"] },
    "test": { "dependsOn": ["^build", "^test"] },
    "dev": { "cache": false, "persistent": true }
  }
}
